$font = JetBrainsMono Nerd Font
$font_size = 16
$text_start_x = 820

general {
    hide_cursor = true
    ignore_empty_input = true
}

animations {
    enabled = true
}

background {
    monitor =
    path = ~/.cache/hyprlock-frames/frame_0001.png
    reload_cmd = ~/.config/hypr/scripts/hyprlock-frame-cycle.sh
    reload_time = 1
    crossfade_time = 0.4
}

input-field {
    monitor =
    size = 300, 48
    rounding = 0
    outline_thickness = 1
    inner_color = rgba(30, 30, 46, 0.85)
    outer_color = rgba(137, 180, 250, 1.0)
    check_color = rgba(137, 180, 250, 1.0)
    fail_color = rgba(243, 139, 168, 1.0)
    font_color = rgba(205, 214, 244, 1.0)
    fade_on_empty = false
    font_family = $font Bold
    placeholder_text = password
    fail_text = authentication failed
    dots_text_format = *
    dots_size = 0.32
    dots_spacing = 0.32
    position = 0, 0
    halign = center
    valign = center
}

label {
    text = welcome, $USER!
    font_family = $font Bold
    font_size = $font_size
    color = rgba(137, 180, 250, 1.0)
    halign = left
    valign = center
    position = $text_start_x, 137
}

label {
    text = cmd[update:60000] echo "<span foreground='##c4c5d6'>date: </span>$(date +'%d %b, %a.' | awk '{print tolower($0)}')"
    ...
}
label {
    text = cmd[update:3000] echo "<span foreground='##c4c5d6'>time: </span>$(date +'%H:%M')"
    ...
}
label {
    text = <span foreground='##c4c5d6'>key:  </span>$LAYOUT[us,rs]
    ...
}
